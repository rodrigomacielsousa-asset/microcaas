{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "CartItem": {
      "title": "Cart Item",
      "description": "An item in the user's cart",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "priceAtAddition": { "type": "number" },
        "name": { "type": "string" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "A completed purchase order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "#/entities/CartItem" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Purchase orders"
    }
  }
}
